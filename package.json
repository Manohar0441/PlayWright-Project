{
  "name": "streamz-playwright-practice",
  "version": "1.0.0",
  "private": true,
  "description": "Streamz — a small streaming media-player web app (frontend + zero-dependency Node backend) built as a practice target for Playwright UI / API / Integration automation.",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "playwright test",
    "test:unit": "playwright test --project=unit",
    "test:api": "playwright test --project=api",
    "test:integration": "playwright test --project=integration",
    "test:smoke": "playwright test --project=smoke",
    "test:e2e": "playwright test --project=e2e",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:e2e:headed": "playwright test --project=e2e --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report"
  },
  "engines": {
    "node": ">=18.19"
  },
  "devDependencies": {
    "@playwright/test": "1.61.0"
  }
}
